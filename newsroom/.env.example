# ─────────────────────────────────────────────────────────────────
#  newsroom 파이프라인 환경변수  (복사 → .env 로 저장 후 값 채우기)
#  .env 는 절대 커밋하지 마세요 (.gitignore 에 이미 등록됨)
# ─────────────────────────────────────────────────────────────────

# ── AI (Claude) : 1차 선별 + 카피/스크립트 작성 ──────────────────
ANTHROPIC_API_KEY=

# ── 이미지 생성 : 아래 둘 중 PROVIDER 로 택1 (config/ai.yaml 의 image.provider) ──
# 1) 추천: 구글 Gemini / Imagen
GOOGLE_API_KEY=
# 2) 현재 구독 중인 Grok (xAI)
XAI_API_KEY=

# ── 텔레그램 (Human-in-the-Loop 검토) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=          # 내 개인 chat id (봇에게 아무 메시지 → run_ai_bot.py 로그에 표시)

# ── 릴스 : 힉스필드 비디오 AI ────────────────────────────────────
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_BASE=https://platform.higgsfield.ai   # 실제 엔드포인트로 교체

# ── TTS(나레이션 음성) : 택1 ─────────────────────────────────────
# ELEVENLABS_API_KEY=       # ElevenLabs (한국어 자연스러움 우수)
# GOOGLE_API_KEY 재사용     # Google Cloud TTS 사용 시

# ── 인스타그램 Instagram Graph API ──────────────────────────────
IG_USER_ID=                # 인스타그램 비즈니스 계정 ID (숫자)
IG_ACCESS_TOKEN=           # 장기(long-lived) 페이지 액세스 토큰
# 릴스/카드뉴스 업로드는 "공개 URL"이 필요 → 완성 파일을 올릴 호스팅(예: S3/R2/GCS)
PUBLIC_ASSET_BASE_URL=     # 예: https://cdn.example.com/newsroom
