# ═══════════════════════════════════════════════════════════════════
#  한국어 채널 전용 자격증명 (.env.ko 로 복사해서 채우세요)
#  · 공통 .env 위에 이 파일이 '덮어쓰기'로 로드됩니다.
#  · 여기 넣지 않은 값(예: R2)은 공통 .env 값을 그대로 씁니다.
#    → R2를 공유하면 R2_* 는 생략 가능. 텔레그램/인스타는 반드시 별도!
# ═══════════════════════════════════════════════════════════════════

# ── 한국어 채널용 텔레그램 봇 (BotFather 로 새 봇 생성) ──
TELEGRAM_BOT_TOKEN=여기에_한국어채널_봇토큰
TELEGRAM_CHAT_ID=여기에_본인_chat_id

# ── 한국어 채널용 인스타그램 계정 (별도 계정 + 토큰) ──
INSTAGRAM_ACCESS_TOKEN=여기에_한국어채널_인스타_토큰
INSTAGRAM_USER_ID=여기에_한국어채널_인스타_비즈니스_계정ID

# ── (선택) R2 를 일본어 채널과 분리하려면 아래도 지정 ──
# R2_BUCKET=newsroom-assets-ko
# PUBLIC_ASSET_BASE_URL=https://<...>.r2.dev

# ── AI/이미지 키는 보통 공통 .env 로 충분(생략 가능) ──
# ANTHROPIC_API_KEY=...
# XAI_API_KEY=...
