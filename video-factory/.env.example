# ───────────────────────────────────────────────────────────────
# video-factory 환경설정 예시
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요.  cp .env.example .env
# (.env 는 .gitignore 에 의해 커밋되지 않습니다)
# ───────────────────────────────────────────────────────────────

# ── 대본/메타데이터/프롬프트 생성용 LLM (기본: xAI Grok) ──────────
# 둘 중 키가 있는 쪽을 TEXT_PROVIDER 로 고르면 됩니다. (xai | openai | anthropic)
TEXT_PROVIDER=xai

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
# 텍스트(대본) 생성 모델. xAI 콘솔에서 최신 모델명 확인 후 교체하세요.
XAI_TEXT_MODEL=grok-4.3
# 이미지 생성 모델 (계정에서 쓸 수 있는 정확한 이름은 UI '모델 보기'로 확인)
XAI_IMAGE_MODEL=grok-imagine-image-quality
# 인트로용 영상 생성 모델 (Grok Imagine). 이미지→영상만 지원.
XAI_VIDEO_MODEL=grok-imagine-video-1.5

# ── (선택) OpenAI 를 텍스트/이미지에 쓰고 싶을 때 ────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# ── (선택) Anthropic 을 텍스트에 쓰고 싶을 때 ──────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_TEXT_MODEL=claude-opus-4-8

# ── TTS(음성) — ElevenLabs ───────────────────────────────────
# 대본을 음성 + 자막(SRT)으로 자동 생성. UI '보이스 목록 불러오기'로 voiceId 선택.
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=
# 음성 속도 0.7(느림)~1.2(빠름), 1.0 기본
ELEVENLABS_SPEED=1.0

# ── 자막 자동 수집(--url) 설정 ────────────────────────────────
# 유튜브 자막을 yt-dlp 로 받아온다. 외부망이 열린 환경 + yt-dlp 설치 필요.
#   설치: pip install -U yt-dlp   (또는 brew install yt-dlp)
# yt-dlp 가 PATH 에 없으면 절대경로를 지정(보통 비워둬도 자동 탐색):
YTDLP_PATH=
# 최신 yt-dlp 는 유튜브 추출에 JS 런타임 필요. 기본값으로 이 프로그램의 Node 를 자동 사용.
# 별도 지정이 필요하면: node:C:\\path\\to\\node.exe  또는  deno
YTDLP_JS_RUNTIME=

# ── 영상 공통 설정 ────────────────────────────────────────────
# 채널 톤/페르소나 (대본 문체에 반영됨)
CHANNEL_NAME=호감의 심리학
CHANNEL_PERSONA=차분하고 신뢰감 있는 30대 남성 내레이터. 단정적이되 따뜻하고, 심리학 근거를 곁들여 설득력 있게 말한다.
# 영상 목표 길이(분). 대본 분량 산정에 사용.
TARGET_MINUTES=7
# 이미지 그림체/분위기(영어). 비워두면 보기 편한 부드러운 플랫 일러스트가 기본.
# 예) "cinematic 3d render, pixar style, soft lighting"  /  "watercolor storybook illustration"
IMAGE_STYLE=
# 이미지/영상 화면비
IMAGE_ASPECT_RATIO=16:9
VIDEO_ASPECT_RATIO=16:9
# 인트로 클립 길이(초)
INTRO_CLIP_SECONDS=6
